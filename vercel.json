{
  "outputDirectory": "dist/angular-app",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://campvia-api.onrender.com/api/:path*"
    },
    {
      "source": "/uploads/:path*",
      "destination": "https://campvia-api.onrender.com/uploads/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
{
    "experimentalServices": {
        "frontend": {
            "routePrefix": "/",
            "framework": "angular"
        },
        "backend": {
            "entrypoint": "backend",
            "routePrefix": "/_/backend"
        }
    }
}
