{
  "name": "angular-app",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "build:prod": "ng build --configuration production",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "dev:free-ports": "kill-port 5000 4200",
    "dev:mongo": "echo Using MongoDB Atlas; skipping local MongoDB service start",
    "dev:backend": "cd backend && node server.js",
    "dev:backend:watch": "cd backend && node_modules\\.bin\\nodemon server.js",
    "dev:frontend": "ng serve",
    "dev:all": "npm run dev:free-ports && npm run dev:mongo && concurrently --kill-others-on-fail --names \"BACKEND,FRONTEND\" --prefix-colors \"yellow.bold,cyan.bold\" \"npm run dev:backend\" \"npm run dev:frontend\"",
    "start:backend": "cd backend && node server.js"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "packageManager": "npm@11.7.0",
  "dependencies": {
    "@angular/animations": "^21.1.5",
    "@angular/common": "^21.1.0",
    "@angular/compiler": "^21.1.0",
    "@angular/core": "^21.1.0",
    "@angular/forms": "^21.1.5",
    "@angular/platform-browser": "^21.1.0",
    "@angular/router": "^21.1.0",
    "@google/generative-ai": "^0.24.1",
    "jspdf": "^4.2.0",
    "lucide-angular": "^0.575.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.1.4",
    "@angular/cli": "^21.1.4",
    "@angular/compiler-cli": "^21.1.0",
    "autoprefixer": "^10.4.17",
    "concurrently": "^9.2.1",
    "kill-port": "^2.0.1",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "typescript": "~5.9.2"
  }
}
