PORT=5000
MONGODB_URI=mongodb+srv://<db_user>:<db_password>@cluster0.xxxxx.mongodb.net/fs-angular-app?retryWrites=true&w=majority&appName=Cluster0
JWT_SECRET=replace_with_a_long_random_secret
GEMINI_API_KEY=replace_with_your_gemini_key
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=replace_with_razorpay_secret

# Comma separated frontend origins allowed to call API
# Example: https://your-app.vercel.app,https://www.your-domain.com
CORS_ORIGIN=https://your-app.vercel.app
